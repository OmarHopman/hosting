local animation = {}

local ts = game:GetService("TweenService")

function animation.onCreate(item,name,startTime,endTime,animeSpeed)
	if name == "HappyCube" then
		local ti = TweenInfo.new(animeSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
		local ti2 = TweenInfo.new(animeSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
		local thin = {
			Rotation = 360,
			Size = UDim2.new(1,0,1,0),
			BackgroundColor3 = Color3.fromRGB(28, 88, 255),
			BackgroundTransparency = 0
		}

		local thin2 = {
			Rotation = 0,
			Size = UDim2.new(0,0,0,0),
			BackgroundColor3 = Color3.fromRGB(28, 88, 255),
			BackgroundTransparency = 1
		}

		local c = ts:Create(item, ti, thin)
		local c2 = ts:Create(item, ti2, thin2)
		wait(startTime)
		c:Play()
		wait(endTime)
		c2:Play()

	elseif name == "Woop" then
		local ti = TweenInfo.new(animeSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
		local ti2 = TweenInfo.new(animeSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
		local thin = {
			Size = UDim2.new(3,0,3,0),
			BackgroundTransparency = 0
		}

		local thin2 = {
			Size = UDim2.new(0,0,0,0),
			BackgroundTransparency = 1
		}

		local c = ts:Create(item, ti, thin)
		local c2 = ts:Create(item, ti2, thin2)
		wait(startTime)
		c:Play()
		wait(endTime)
		c2:Play()

	elseif name == "Fade" then
		local ti = TweenInfo.new(animeSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
		local ti2 = TweenInfo.new(animeSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
		local thin = {
			Position = UDim2.new(0.499, 0,0.5, 0),
			BackgroundTransparency = 0
		}

		local thin2 = {
			Position = UDim2.new(2,0,0.5,0),
			BackgroundTransparency = 1
		}

		local c = ts:Create(item, ti, thin)
		local c2 = ts:Create(item, ti2, thin2)
		wait(startTime)
		c:Play()
		wait(endTime)
		c2:Play()

	elseif name == "Anim" then
		local ti = TweenInfo.new(animeSpeed, Enum.EasingStyle.Elastic, Enum.EasingDirection.In)
		local ti2 = TweenInfo.new(animeSpeed, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out)
		local thin = {
			Rotation = 360,
			BackgroundTransparency = 0,
			Size = UDim2.new(1,0,1,0)
		}

		local thin2 = {
			Rotation = 0,
			BackgroundTransparency = 1,
			Size = UDim2.new(0,0,0,0)
		}

		local c = ts:Create(item, ti, thin)
		local c2 = ts:Create(item, ti2, thin2)
		wait(startTime)
		c:Play()
		wait(endTime)
		c2:Play()

	elseif name == "Joe" then
		item.Position = UDim2.new(0.499, 0,0.5, 0)
		item.Size = UDim2.new(0.122, 0,0.199, 0)
		item.AnchorPoint = Vector2.new(0.5,0.5)
		local ti = TweenInfo.new(animeSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
		local thin = {
			Rotation = 360
		}
		local thin2 = {
			Rotation = 0
		}
		local thin3 = {
			Size = UDim2.new(1,0,1,0)
		}

		local thin4 = {
			Size = UDim2.new(0,0,0,0),
			BackgroundTransparency = 1
		}

		local c = ts:Create(item, ti, thin)
		local c2 = ts:Create(item, ti, thin2)
		local c3 = ts:Create(item, ti, thin3)
		local c4 = ts:Create(item, ti, thin4)

		wait(startTime)
		c:Play()
		wait(1)
		c2:Play()
		wait(1)
		c3:Play()
		wait(endTime)
		c4:Play()

	elseif name == "Dance" then
		local ti = TweenInfo.new(animeSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
		local thin = {
			Rotation = 10
		}

		local thin2 = {
			Rotation = -10
		}

		local c = ts:Create(item, ti, thin)
		local c2 = ts:Create(item, ti, thin2)
		while wait() do
			wait(startTime + .2)
			c:Play()
			wait(startTime + .3)
			c2:Play()
		end
	end
end

function animation.FadeIn(item,speed,name)
	local ti = TweenInfo.new(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
	if name == "TextTransparency" or name == "Text" then
		local thin = {
			TextTransparency = 1
		}
		local c = ts:Create(item, ti, thin)
		c:Play()
		
	elseif name == "ImageTransparency" or name == "Image" then
		local thin = {
			ImageTransparency = 1
		}
		local c = ts:Create(item, ti, thin)
		c:Play()
	else
		local thin = {
			BackgroundTransparency = 1
		}
		local c = ts:Create(item, ti, thin)
		c:Play()
	end
end

function animation.FadeOut(item,speed,name)
	local ti = TweenInfo.new(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
	if name == "TextTransparency" or name == "Text" then
		local thin = {
			TextTransparency = 0
		}
		local c = ts:Create(item, ti, thin)
		c:Play()

	elseif name == "ImageTransparency" or name == "Image" then
		local thin = {
			ImageTransparency = 0
		}
		local c = ts:Create(item, ti, thin)
		c:Play()
	else
		local thin = {
			BackgroundTransparency = 0
		}
		local c = ts:Create(item, ti, thin)
		c:Play()
	end
end

function animation.Move(item,speed,position)
	item:TweenPosition(position, "In", "Linear", speed)
end

function animation.Size(item,speed,size)
	item:TweenSize(size, "In", "Linear", speed)
end

function animation.Drag(item)
	local UIS = game:GetService("UserInputService")
	dragToggle = nil
	local dragSpeed = 0
	dragInput = nil
	dragStart = nil
	local dragPos = nil
	function updateInput(input)
		local Delta = input.Position - dragStart
		local Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + Delta.X, startPos.Y.Scale, startPos.Y.Offset + Delta.Y)
		game:GetService("TweenService"):Create(item, TweenInfo.new(0.25), {Position = Position}):Play()
	end
	item.InputBegan:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and UIS:GetFocusedTextBox() == nil then
			dragToggle = true
			dragStart = input.Position
			startPos = item.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragToggle = false
				end
			end)
		end
	end)
	item.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	game:GetService("UserInputService").InputChanged:Connect(function(input)
		if input == dragInput and dragToggle then
			updateInput(input)
		end
	end)
end

return animation
